# --- Secrets & environment (never commit real keys) ---
**/.env
**/.env.*
!.env.example
!**/.env.example
!.env.*.example
!**/.env.*.example

**/.env.local
**/.env.*.local
.env.local
.env.development.local
.env.test.local
.env.production.local

# Key material & credential files
**/*.pem
**/*.key
**/*.p12
**/*.pfx
**/secrets.json
**/credentials.json
**/*-credentials.json

# Optional: local tooling tokens
.ngrok2/
*.ngrok
