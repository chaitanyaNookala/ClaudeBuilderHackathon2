# PulseBot Environment Configuration
# Copy this to .env and fill in your values

# Discord Bot — https://discord.com/developers/applications → Bot → Reset Token
DISCORD_BOT_TOKEN=your_bot_token_here
GUILD_ID=optional_guild_id_for_testing

# Gemini API (for /stuck coaching) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Server Port (FirstPath is served here too: http://localhost:3000)
PORT=3000
